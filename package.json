{
  "name": "tinted-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Static, client-only web app for crafting Tinted Theming color schemes (Base16, Base24, Tinted8).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "parity:extract": "tsx scripts/parity/run.mts",
    "build:grammars": "node scripts/build-grammars.mjs",
    "check": "npm run typecheck && npm run lint && npm run test"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@replit/codemirror-indentation-markers": "^6.5.3",
    "@replit/codemirror-vim": "^6.3.0",
    "colorthief": "^3.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "web-tree-sitter": "^0.25.10",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "@vitejs/plugin-react": "^4.3.3",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.14",
    "prettier": "^3.3.3",
    "tree-sitter-cli": "^0.26.9",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}
